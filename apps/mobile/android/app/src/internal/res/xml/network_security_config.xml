<?xml version="1.0" encoding="utf-8"?>
<!--
  Internal/trusted phone build network policy.

  This variant is debug-signed and intended for private VPN/LAN testing, where
  ease of setup matters more than TLS ceremony. Release builds continue to use
  src/main/res/xml/network_security_config.xml.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
