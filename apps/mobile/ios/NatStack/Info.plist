<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>NatStack</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!--
		CFBundleURLTypes: registers the `natstack://` custom URL scheme.
		This is now a TRANSITIONAL FALLBACK only — the primary OAuth
		callback path is the universal link
		https://auth.snugenv.com/oauth/callback/<provider>?... declared in
		NatStack.entitlements (associated-domains). The custom scheme is
		kept so devices that haven't completed App-Site Association
		verification don't get locked out (cold-start before AASA fetch,
		users on networks that block apple-app-site-association.cdn.apple.com).
		oauthHandler.ts emits `warn` on every custom-scheme hit; once
		telemetry shows zero fallback usage the entry below can be
		removed. See docs/audit/08-mobile-supply-chain.md H-2.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>natstack</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.natstack.mobile</string>
		</dict>
	</array>
	<!--
		NSAppTransportSecurity: ATS is enforced by default. Cleartext is
		allowed ONLY for the loopback addresses used by `npm run ios`
		against a local NatStack server. NSAllowsLocalNetworking permits
		LAN/loopback (no public-internet cleartext) and per-domain
		exceptions cover the literal hosts the dev server binds to.
		TODO(security-audit-agent-5): if a developer needs cleartext
		against another host (e.g. a *.nip.io or *.lvh.me wildcard for
		panel subdomain routing during local dev), add a scoped
		NSExceptionDomains entry rather than re-enabling
		NSAllowsArbitraryLoads. Production releases must NOT add public
		cleartext domains here; the React Native shell talks to the
		server over wss:// and panel pages over https://.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>127.0.0.1</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
