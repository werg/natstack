{
  "type": "module",
  "name": "natstack",
  "version": "0.1.0",
  "private": true,
  "description": "A horizontally stacked panel app built with Electron and TypeScript",
  "main": "dist/main.cjs",
  "bin": {
    "natstack-server": "dist/server.mjs",
    "natstack-client": "dist/cli/client.mjs"
  },
  "scripts": {
    "prebuild": "node scripts/generate-channels.mjs && node scripts/generate-injected.mjs",
    "build": "NODE_ENV=production node build.mjs",
    "build:dist": "pnpm build",
    "dev": "export NODE_ENV=development && node build.mjs && (pnpm type-check &) && node scripts/run-electron.mjs",
    "start": "node scripts/run-electron.mjs",
    "server": "node dist/server.mjs",
    "server:dev": "NODE_ENV=development node dist/server.mjs",
    "pair": "node scripts/pair.mjs",
    "dev:mobile-server": "node scripts/dev-mobile-server.mjs",
    "mobile:pair": "node scripts/mobile-pair.mjs",
    "mobile:pair:dev": "node scripts/mobile-pair.mjs --dev",
    "mobile:apk:internal": "node scripts/install-mobile-internal.mjs --build-only",
    "mobile:install:internal": "node scripts/install-mobile-internal.mjs",
    "mobile:logs:internal": "node scripts/mobile-logs.mjs",
    "mobile:emulator": "node scripts/start-mobile-emulator.mjs",
    "mobile:dev": "node scripts/start-mobile-dev.mjs",
    "mobile:clean": "rm -rf apps/mobile/node_modules && pnpm install",
    "pack": "pnpm build:dist && electron-builder --dir",
    "dist": "pnpm build:dist && electron-builder",
    "dist:mac": "pnpm build:dist && electron-builder --mac",
    "dist:win": "pnpm build:dist && electron-builder --win",
    "dist:linux": "pnpm build:dist && electron-builder --linux",
    "generate:runtime-docs": "node scripts/generate-runtime-docs.mjs",
    "check:runtime-docs": "node scripts/generate-runtime-docs.mjs --check",
    "dev:debug": "NATSTACK_DEBUG_PATHS=1 pnpm dev",
    "dev:verbose": "NATSTACK_LOG_LEVEL=verbose pnpm dev",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,html,json}'",
    "quality:check": "pnpm type-check && pnpm lint && pnpm format:check",
    "type-check": "tsc --noEmit && tsc --project tsconfig.workspace.json",
    "type-check:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "pnpm run check:runtime-docs && vitest run",
    "test:extension-smoke": "NODE_ENV=development node build.mjs && NATSTACK_RUN_SERVER_INTEGRATION=1 vitest run tests/extension-image-service.integration.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c tests/config/playwright.config.ts",
    "test:e2e:headed": "playwright test -c tests/config/playwright.config.ts --headed",
    "test:all": "pnpm test && pnpm test:e2e",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "typescript",
    "panel"
  ],
  "author": "Gabriel Pickard",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "allowedBuilds": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-git-server",
      "node-pty"
    ],
    "//overrides": "react-native 0.79 peerDeps react ^19.0.0. Pinning here prevents hoisted React 18 (pulled in transitively by workspace deps) from shadowing RN's requirement in the mobile bundle. protobufjs ^7.5.5 patches RCE GHSA-xq3m-2v4x-88gg reachable via @google/genai → pi-ai. Revisit when bumping RN.",
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "protobufjs": "^7.5.5"
    },
    "patchedDependencies": {
      "re2@1.24.0": "patches/re2@1.24.0.patch",
      "@earendil-works/pi-agent-core@0.74.1": "patches/@earendil-works__pi-agent-core@0.74.1.patch"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/npmcli__arborist": "^6.3.1",
    "@types/pacote": "^11.1.8",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@workspace/about-shared": "workspace:*",
    "@workspace/agentic-chat": "workspace:*",
    "@workspace/agentic-components": "workspace:*",
    "@workspace/agentic-do": "workspace:*",
    "@workspace/core": "workspace:*",
    "@workspace/eval": "workspace:*",
    "@workspace/git-ui": "workspace:*",
    "@workspace/react": "workspace:*",
    "@workspace/runtime": "workspace:*",
    "@workspace/tool-ui": "workspace:*",
    "buffer": "^6.0.3",
    "electron": "^39.2.5",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "esbuild-svelte": "^0.9.4",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "qrcode-terminal": "^0.12.0",
    "sql.js": "^1.14.0",
    "svelte": "^5.55.0",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-agent-core": "^0.74.1",
    "@earendil-works/pi-ai": "^0.74.1",
    "@ghostery/adblocker": "^2.13.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@natstack/browser-data": "workspace:*",
    "@natstack/dev-log": "workspace:*",
    "@natstack/env-paths": "workspace:*",
    "@natstack/extension": "workspace:*",
    "@natstack/extension-host": "workspace:*",
    "@natstack/git": "workspace:*",
    "@natstack/git-server": "workspace:*",
    "@natstack/harness": "workspace:*",
    "@natstack/port-utils": "workspace:*",
    "@natstack/process-adapter": "workspace:*",
    "@natstack/pubsub": "workspace:*",
    "@natstack/rpc": "workspace:*",
    "@natstack/shared": "workspace:*",
    "@natstack/typecheck": "workspace:*",
    "@natstack/types": "workspace:*",
    "@npmcli/arborist": "^7.4.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/json-schema": "^7.0.15",
    "@types/ws": "^8.18.1",
    "ajv": "^8.17.1",
    "chokidar": "^5.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "firebase-admin": "^12.7.0",
    "isomorphic-git": "^1.30.1",
    "jotai": "^2.15.1",
    "node-git-server": "^1.0.0",
    "node-pty": "^1.0.0",
    "npm": "^11.13.0",
    "p-limit": "^6.2.0",
    "pacote": "^21.0.0",
    "pathe": "^2.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tldts": "^7.0.19",
    "typescript": "^5.9.3",
    "workerd": "^1.20260310.1",
    "ws": "^8.18.3",
    "xterm": "^5.3.0",
    "xterm-addon-canvas": "^0.5.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0",
    "yaml": "^2.8.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.0"
  }
}
