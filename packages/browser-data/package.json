{
  "name": "@natstack/browser-data",
  "version": "0.1.0",
  "description": "Browser data import/export and storage for NatStack",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^3.24.1",
    "@types/sql.js": "^1.4.11"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  },
  "files": [
    "dist"
  ]
}
