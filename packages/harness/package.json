{
  "name": "@natstack/harness",
  "version": "0.1.0",
  "description": "Shared type definitions for the NatStack agentic harness messaging system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./entry": {
      "default": "./dist/entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "@natstack/rpc": "workspace:*",
    "re2": "^1.24.0",
    "ws": "^8.18.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3"
  }
}
