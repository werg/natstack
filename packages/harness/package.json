{
  "name": "@natstack/harness",
  "version": "0.1.0",
  "description": "Shared type definitions for the NatStack agentic harness messaging system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./web-extract": {
      "types": "./dist/web-extract.d.ts",
      "default": "./dist/web-extract.js"
    },
    "./entry": {
      "default": "./dist/entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.1",
    "@mozilla/readability": "^0.6.0",
    "@natstack/rpc": "workspace:*",
    "@natstack/shared": "workspace:*",
    "@workspace/agentic-protocol": "workspace:*",
    "@workspace/pi-adapter": "workspace:*",
    "linkedom": "^0.18.5",
    "unpdf": "^1.6.2",
    "ws": "^8.18.0",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "re2": "1.24.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.97.1",
    "@aws-sdk/client-bedrock-runtime": "3.1039.0",
    "@mistralai/mistralai": "2.2.1"
  },
  "//": "re2 pinned to exact version to match patches/re2@1.24.0.patch",
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3"
  }
}
