      "@workspace/svelte": [
        "workspace/packages/svelte/src/index.ts"
      ],
      "@workspace/tool-ui": [
        "workspace/packages/tool-ui/src/index.ts"
      ]
    }
  },
  "include": [
    "workspace/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/node_modules",
    "workspace/packages/playwright-*"
  ]
}
