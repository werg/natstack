{
  "name": "@workspace-workers/gad-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "title": "Gad Workspace Store",
    "kind": "worker",
    "entry": "index.ts",
    "durable": {
      "classes": [{ "className": "GadWorkspaceDO" }]
    },
    "services": [
      {
        "name": "gad.workspace",
        "title": "gad Workspace Store",
        "protocols": ["natstack.gad.workspace.v1"],
        "durableObject": { "className": "GadWorkspaceDO", "objectKey": "workspace-gad" }
      }
    ]
  },
  "dependencies": {
    "@workspace/runtime": "workspace:*"
  }
}
