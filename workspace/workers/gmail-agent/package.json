{
  "name": "@workspace-workers/gmail-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "entry": "index.ts",
    "durable": {
      "classes": [{ "className": "GmailAgentWorker" }]
    },
    "exposeModules": [
