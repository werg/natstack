{
  "name": "@workspace-apps/shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "displayName": "NatStack Shell",
    "app": {
      "target": "electron",
      "renderer": "index.tsx",
      "capabilities": [
        "native-menus",
        "notifications",
        "open-external",
        "window-management",
        "panel-hosting",
        "incoming-pair-links",
        "connection-management"
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@natstack/rpc": "workspace:*",
    "@natstack/shared": "workspace:*",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/react-virtual": "^3.13.0",
    "@workspace/react": "workspace:*",
    "jotai": "^2.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
