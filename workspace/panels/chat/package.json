{
  "name": "@workspace-panels/chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "title": "Agentic Chat",
    "entry": "index.tsx",
    "stateArgs": {
      "type": "object",
      "properties": {
        "channelName": {
          "type": "string",
          "description": "Channel to connect to"
        },
        "channelConfig": {
          "type": "object",
          "description": "Channel configuration"
        },
        "contextId": {
          "type": "string",
          "description": "Context ID for channel authorization"
        },
        "pendingAgents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "agentId": { "type": "string" },
              "handle": { "type": "string" }
            }
          },
          "description": "Agents pending subscription"
        },
        "agentSource": {
          "type": "string",
          "description": "Worker source path for the default agent DO"
        },
        "agentClass": {
          "type": "string",
          "description": "DO class name for the default agent"
        },
        "initialPrompt": {
          "type": "string",
          "description": "Initial prompt to auto-send as the first user message"
        },
        "systemPrompt": {
          "type": "string",
          "description": "System prompt for the agent harness"
        },
        "systemPromptMode": {
          "type": "string",
          "enum": ["append", "replace-natstack", "replace"],
          "description": "append (default): layers on NatStack base + workspace prompt + skill index. replace-natstack: replaces the NatStack base while preserving workspace prompt + skill index. replace: replaces everything."
        }
      }
    },
    "exposeModules": [
      "react",
      "react/jsx-runtime",
      "react/jsx-dev-runtime",
      "@radix-ui/themes",
      "@radix-ui/react-icons",
      "isomorphic-git",
      "@workspace/runtime",
      "@workspace/panel-browser",
      "@workspace/playwright-client"
    ]
  },
  "dependencies": {
    "@workspace/runtime": "workspace:*",
    "@workspace/panel-browser": "workspace:*",
    "@workspace/playwright-client": "workspace:*",
    "@workspace/react": "workspace:*",
    "@workspace/agentic-chat": "workspace:*",
    "@workspace/eval": "workspace:*",
    "@natstack/pubsub": "workspace:*",
    "@radix-ui/themes": "^3.2.1",
    "@radix-ui/react-icons": "^1.3.2",
    "zod": "^3.22.0"
  }
}
